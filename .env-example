# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fullstack

# Backend
# MODE: set to "prod" when deploying (enables the placeholder-secret guard)
MODE=dev
DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/fullstack
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Auth cookies (tokens are httpOnly cookies set by the backend)
# COOKIE_SECURE MUST be true in production (requires HTTPS); false for local http
COOKIE_SECURE=false

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
# NEXT_PUBLIC_API_URL is the browser-facing backend URL, inlined at build time.
# Change it for prod and rebuild (make build), not just restart.
NEXT_PUBLIC_API_URL=http://localhost:8000
