# Only needed when running the frontend standalone (pnpm dev) outside Docker.
# In the Docker stack these come from the root .env via docker-compose.

# Browser -> backend (inlined into the client bundle at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL (used by sitemap.ts / robots.ts)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side (SSR/RSC) -> backend. In Docker this is http://backend:8000;
# for standalone dev it can mirror NEXT_PUBLIC_API_URL.
API_URL=http://localhost:8000
