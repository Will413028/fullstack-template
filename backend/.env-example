# For running the backend standalone (make run) outside Docker.
# The Docker stack uses the root .env instead.

# App
MODE=dev

# Database
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/fullstack

# Auth
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Auth cookies — false for local http; MUST be true in production (HTTPS)
COOKIE_SECURE=false

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:3000"]
